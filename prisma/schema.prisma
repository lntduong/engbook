generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_DATA")
}

model Vocabulary {
  id        String   @id @default(uuid())
  word      String
  ipa       String?
  meaning   String
  level     String   @default("A1")
  type      String   @default("noun")
  lesson    String?
  example   String?
  dateAdded DateTime @default(now())

  @@index([level])
  @@index([word])
}

model Grammar {
  id          String   @id @default(uuid())
  title       String
  level       String
  category    String
  order       Int      @default(0)
  explanation String   @db.Text
  structure   String?  @db.Text
  examples    String   @db.Text
  notes       String?  @db.Text
  dateAdded   DateTime @default(now())

  @@index([level])
  @@index([category])
}

model Listening {
  id         String   @id @default(uuid())
  title      String
  level      String
  topic      String
  order      Int      @default(0)
  audioUrl   String
  duration   String
  transcript String   @db.Text
  notes      String?  @db.Text
  myWriting  String?  @db.Text
  dateAdded  DateTime @default(now())

  @@index([level])
  @@index([topic])
}

model Note {
  id          String   @id @default(uuid())
  title       String
  content     String   @db.Text
  category    String?
  tags        String[]
  order       Int      @default(0)
  dateCreated DateTime @default(now())
  lastEdited  DateTime @updatedAt

  @@index([category])
}
